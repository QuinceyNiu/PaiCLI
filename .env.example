GLM_API_KEY=your_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-5.1

# Web search/fetch tools
# 默认无需额外配置：PaiCLI 会复用 GLM_API_KEY 作为智谱搜索 API Key。
# 可选值: zhipu / serpapi / searxng
# SEARCH_PROVIDER=zhipu
# ZHIPU_SEARCH_ENGINE=search_std

# SerpAPI:
# SEARCH_PROVIDER=serpapi
# SERPAPI_KEY=your_serpapi_key_here

# SearXNG:
# docker run --rm -p 8888:8888 searxng/searxng
# SEARCH_PROVIDER=searxng
# SEARXNG_URL=http://localhost:8888

# MCP
# PaiCLI 会读取 ~/.paicli/mcp.json 和当前项目 .paicli/mcp.json。
# 项目级配置优先，可以在配置中用 ${GLM_API_KEY}、${HOME}、${PROJECT_DIR}。
